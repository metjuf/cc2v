# ═══════════════════════════════════════════
# REQUIRED — at least one LLM key needed
# ═══════════════════════════════════════════

# Anthropic API key (PRIMARY — best quality)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (FALLBACK + auxiliary tasks)
OPENROUTER_API_KEY=sk-or-...

# ═══════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════

# Primary chat model (Anthropic)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback chat model (OpenRouter)
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Auxiliary model for emotion detection, summarization, fact extraction (OpenRouter)
AUX_MODEL=google/gemini-2.0-flash-001

# ═══════════════════════════════════════════
# TTS CONFIGURATION
# ═══════════════════════════════════════════

# TTS voice (edge-tts — free Microsoft Azure neural voices)
# Czech: cs-CZ-VlastaNeural (female), cs-CZ-AntoninNeural (male)
# English: en-GB-SoniaNeural, en-US-JennyNeural, en-US-AriaNeural
TTS_VOICE=cs-CZ-VlastaNeural

# TTS enabled by default
TTS_ENABLED=true

# ═══════════════════════════════════════════
# ASSISTANT IDENTITY
# ═══════════════════════════════════════════

# Assistant name (displayed in UI and used in system prompt)
ASSISTANT_NAME=Eigy

# ═══════════════════════════════════════════
# PROACTIVE BEHAVIOR
# ═══════════════════════════════════════════

# Enable proactive messages (assistant speaks up during silence)
PROACTIVE_ENABLED=true

# How many seconds of silence before assistant speaks up (default: 120 = 2 min)
PROACTIVE_IDLE_TIMEOUT=120

# ═══════════════════════════════════════════
# AVATAR CONFIGURATION
# ═══════════════════════════════════════════

AVATAR_WINDOW_WIDTH=500
AVATAR_WINDOW_HEIGHT=600
AVATAR_FPS=30

# Emotion detection: "keyword" (fast) or "llm" (accurate, uses AUX_MODEL)
EMOTION_DETECTION=keyword

# ═══════════════════════════════════════════
# MEMORY CONFIGURATION
# ═══════════════════════════════════════════

# Database path
DATABASE_PATH=data/eigy.db

# How many previous conversation summaries to include in context
MEMORY_SUMMARY_COUNT=5

# How many messages from last session to include verbatim
MEMORY_TAIL_MESSAGES=20

# ═══════════════════════════════════════════
# EPISODIC MEMORY (ChromaDB)
# ═══════════════════════════════════════════

# Enable episodic memory (semantic search over past conversations)
# Requires: pip install chromadb sentence-transformers
EPISODIC_MEMORY_ENABLED=true

# How many relevant past exchanges to include in context
EPISODIC_TOP_K=5

# How many recent user messages to use for episodic query (richer context)
EPISODIC_QUERY_MESSAGES=3

# Path for ChromaDB persistent storage
CHROMADB_PATH=data/chroma

# Auto-prune episodes older than N days with low importance
EPISODIC_MAX_AGE_DAYS=180
EPISODIC_MIN_IMPORTANCE_FOR_KEEP=0.6

# ═══════════════════════════════════════════
# PROFILE EVICTION
# ═══════════════════════════════════════════

# Enable automatic profile condensation at end of each session
PROFILE_EVICTION_ENABLED=true

# How many profile snapshots to keep (backup before condensation)
PROFILE_SNAPSHOT_KEEP=5

# ═══════════════════════════════════════════
# TOKEN BUDGET
# ═══════════════════════════════════════════

# Maximum tokens for entire LLM context (trims lower-priority layers if exceeded)
MAX_CONTEXT_TOKENS=20000

# Per-layer token budgets (used during trimming)
BUDGET_PROFILE=800
BUDGET_SUMMARIES=2000
BUDGET_EPISODIC=1500
BUDGET_PREV_SESSION=1500
BUDGET_MID_SESSION=1000

# ═══════════════════════════════════════════
# HUMAN-LIKE BEHAVIOR
# ═══════════════════════════════════════════

# Temporal awareness (time/day/date in context)
TEMPORAL_AWARENESS_ENABLED=true

# Emotional adaptation (detect and adapt to user mood)
EMOTIONAL_ADAPTATION_ENABLED=true

# Response style variation (hints for natural response variation)
STYLE_VARIATION_ENABLED=true

# Chain-of-thought pre-reasoning (adds ~1-2s latency, more thoughtful responses)
CHAIN_OF_THOUGHT_ENABLED=false

# Eigy's observations about user (personality notes in profile)
EIGY_OBSERVATIONS_ENABLED=true

# Assistant intent tagging in episodic memory
ASSISTANT_INTENT_TAGGING_ENABLED=true

# Smart proactive follow-up (context-aware idle messages)
SMART_PROACTIVE_ENABLED=true

# ═══════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════

# Enable file logging (JSONL system log + per-session exports)
LOG_TO_FILE=true

# System log directory (rotating JSONL, 5MB × 3 backups)
LOG_DIR=data/logs

# Per-session export directory (one JSONL file per conversation)
SESSIONS_DIR=data/sessions
